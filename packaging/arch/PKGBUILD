# Maintainer: Progressive Chat Team <dev@progressive.chat>

pkgname=matrixcli
pkgver=0.1.0
pkgrel=1
pkgdesc="A terminal Matrix client with E2EE, multi-format REST API, and ncurses TUI"
arch=('x86_64')
url="https://github.com/progressive-chat/progressive-cli"
license=('AGPL-3.0-or-later')
depends=(
    'gcc-libs'
    'openssl'
    'libolm'
    'sqlite3'
    'ncurses'
    'nlohmann-json'
)
makedepends=(
    'cmake'
    'gcc'
    'make'
    'pkg-config'
    'git'
)
optdepends=(
    'libnotify: desktop notifications via notify-send'
)
source=("${pkgname}::git+https://github.com/progressive-chat/progressive-cli.git#branch=main")
md5sums=('SKIP')

pkgver() {
    cd "${srcdir}/${pkgname}"
    git describe --long --tags 2>/dev/null | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g' || echo "0.1.0"
}

build() {
    cd "${srcdir}/${pkgname}/cppcli"

    cmake -B build -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DUSE_SYSTEM_OLM=ON \
        -DBUILD_TESTS=OFF \
        -DBUILD_TUI=ON

    cmake --build build -j$(nproc)
}

package() {
    cd "${srcdir}/${pkgname}"

    install -Dm755 cppcli/build/src/matrixcli "${pkgdir}/usr/bin/matrixcli"

    install -Dm644 gomuks/LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    # Desktop entry
    install -dm755 "${pkgdir}/usr/share/applications"
    cat > "${pkgdir}/usr/share/applications/${pkgname}.desktop" << 'EOF'
[Desktop Entry]
Name=matrixcli
Comment=Terminal Matrix client with E2EE
Exec=matrixcli tui
Terminal=true
Type=Application
Categories=Network;InstantMessaging;Chat;
Keywords=matrix;chat;terminal;cli;e2ee;
EOF

    # Bash completion
    install -dm755 "${pkgdir}/usr/share/bash-completion/completions"
    cat > "${pkgdir}/usr/share/bash-completion/completions/matrixcli" << 'EOF'
_matrixcli() {
    local cur prev
    _init_completion || return
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    if [[ $COMP_CWORD -eq 1 ]]; then
        COMPREPLY=($(compgen -W "serve login status tui demo version help" -- "$cur"))
    fi
    case $prev in
        serve|demo)
            COMPREPLY=($(compgen -W "--port --host --demo --help" -- "$cur"))
            ;;
        login)
            COMPREPLY=($(compgen -W "--homeserver --username --password --token --help" -- "$cur"))
            ;;
    esac
}
complete -F _matrixcli matrixcli
EOF
}
