prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@/libmatrix

Name: libmatrix
Description: C++20 Matrix client library with E2EE, SQLite storage, and multi-protocol support
Version: @PROJECT_VERSION@
Requires: openssl libolm sqlite3 nlohmann_json
Libs: -L${libdir} -lmatrix-core -lmatrix-http -lmatrix-db -lmatrix-e2ee
Cflags: -I${includedir} -std=c++20
